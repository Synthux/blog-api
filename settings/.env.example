BLOG_ENV_ID=local
BLOG_SECRET_KEY=long-random-secret-key
BLOG_DEBUG=True
BLOG_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite for local/Docker, PostgreSQL for prod)
BLOG_DB_NAME=blog_db
BLOG_DB_USER=postgres
BLOG_DB_PASSWORD=postgres
BLOG_DB_HOST=localhost
BLOG_DB_PORT=5432

# Redis (use redis://localhost:6379/0 for local, redis://redis:6379/0 for Docker)
BLOG_REDIS_URL=redis://localhost:6379/0
BLOG_CELERY_BROKER_URL=redis://localhost:6379/1

# Flower monitoring
BLOG_FLOWER_USER=admin
BLOG_FLOWER_PASSWORD=changeme

# Seed database on startup (true/false)
BLOG_SEED_DB=false
